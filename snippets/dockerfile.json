{
	// base image
	"ubuntu24": {
		"prefix": "ubuntu24.04",
		"body": [
			"FROM ubuntu:24.04 AS builder",
			"",
			"RUN apt-get update \\",
			"\t&& DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \\",
			"\tcurl \\",
			"\tdirenv \\",
			"\tgit \\",
			"\tgpg \\",
			"\tjq \\",
			"\tpython3-pip \\",
			"\tpython-is-python3 \\",
			"\tssh \\",
			"\ttzdata \\",
			"\tunzip \\",
			"\t&& apt-get clean \\",
			"\t&& rm -rf /var/lib/apt/lists/*",
			"",
			"RUN git config --global --add safe.directory /workspace",
			"",
			"",
			"FROM ubuntu:24.04 AS dev",
			"",
			"COPY --from=builder /usr/bin /usr/bin",
			"COPY --from=builder /usr/lib /usr/lib",
			"COPY --from=builder /usr/share /usr/share",
			"COPY --from=builder /usr/local/bin /usr/local/bin",
			"COPY --from=builder /usr/local/lib /usr/local/lib",
			"",
			"WORKDIR /workspace",
		]
	},
	"nvidia-cuda": {
		"prefix": "nvidia-cuda",
		"body": [
			"FROM nvidia/cuda:12.1.1-cudnn8-devel-ubuntu22.04",
			"",
			"WORKDIR /workspace",
			"",
			"RUN apt-get update \\",
			"\t&& DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \\",
			"\tgit \\",
			"\ttzdata \\",
			"\t&& apt-get clean \\",
			"\t&& rm -rf /var/lib/apt/lists/*",
			"",
			"RUN git config --global --add safe.directory /workspace"
		]
	},
	"python": {
		"prefix": "python3.12",
		"body": [
			"FROM python:3.12",
			"",
			"ADD requirements.txt /",
			"RUN pip install --no-cache-dir --break-system-packages -r requirements.txt"
		]
	},

	// Install Libraires
	"install python": {
		"prefix": "install python",
		"body": [
			"COPY requirements.txt /tmp/",
			"RUN pip install --no-cache-dir --break-system-packages -r /tmp/requirements.txt \\",
			"\t&& rm /tmp/requirements.txt"
		]
	},
	"install python(pytorch/cpu)": {
		"prefix": "install python(pytorch/cpu)",
		"body": [
			"RUN apt-get update \\",
			"\t&& apt-get install -y build-essential git python python3-pip",
			"",
			"COPY requirements.txt /tmp/",
			"RUN pip install --no-cache-dir --break-system-packages -r /tmp/requirements.txt -f https://download.pytorch.org/whl/cpu/torch_stable.html \\",
			"\t&& rm /tmp/requirements.txt"
		]
	},
	"install python(pytorch)": {
		"prefix": "install python(pytorch)",
		"body": [
			"RUN apt-get update \\",
			"\t&& apt-get install -y build-essential git python python3-pip",
			"",
			"COPY requirements.txt /tmp/",
			"RUN pip install --no-cache-dir --break-system-packages -r /tmp/requirements.txt \\",
			"\t&& rm /tmp/requirements.txt"
		]
	},
	"install cmake": {
		"prefix": "install cmake",
		"body": [
			"RUN apt-get update \\",
			"\t&& apt-get upgrade -y \\",
			"\t&& apt-get install -y build-essential git libssl-dev",
			"RUN git clone https://github.com/Kitware/CMake.git \\",
			"\t&& cd CMake \\",
			"\t&& ./bootstrap \\",
			"\t&& make -j8\\",
			"\t&& make install"
		]
	},
	"install nlohmann-json": {
		"prefix": "install nlohmann-json",
		"body": [
			"RUN git clone https://github.com/nlohmann/json.git \\",
			"&& cd json \\",
			"&& cmake . \\",
			"&& make -j8 \\",
			"&& make install"
		]
	},
	"certificates": {
		"prefix": "certificates",
		"body": [
			"COPY ${EXTRA_CA_CERT_PATH} /usr/share/ca-certificates/extra_ca_cert.pem",
			"RUN echo extra_ca_cert.pem >> /etc/ca-certificates.conf",
			"RUN update-ca-certificates",
			"ENV NODE_EXTRA_CA_CERTS=\"/usr/share/ca-certificates/extra_ca_cert.pem\""
		]
	},
	"direnv": {
		"prefix": "direnv",
		"body": [
			"RUN echo \"eval \\\"\\\\$(direnv hook bash)\\\"\" >> ~/.bashrc && /bin/bash -c \"source ~/.bashrc\""
		]
	},
	"node": {
		"prefix": "node",
		"body": [
			"RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && apt-get install -y nodejs"
		]
	},
	"google-cloud-cli": {
		"prefix": "google-cloud-cli",
		"body": [
			"RUN curl https://packages.cloud.google.com/apt/doc/apt-key.gpg | gpg --dearmor -o /usr/share/keyrings/cloud.google.gpg",
			"RUN echo \"deb [signed-by=/usr/share/keyrings/cloud.google.gpg] https://packages.cloud.google.com/apt cloud-sdk main\" | tee -a /etc/apt/sources.list.d/google-cloud-sdk.list",
			"RUN apt-get update && apt-get install -y google-cloud-cli"
		]
	},
	"gemini-cli": {
		"prefix": "gemini-cli",
		"body": [
			"RUN npm install -g @google/gemini-cli"
		]
	},
	"aws-cli": {
		"prefix": "aws-cli",
		"body": [
			"RUN curl \"https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip\" -o \"awscliv2.zip\" \\",
			"\t&& unzip awscliv2.zip \\",
			"\t&& ./aws/install"
		]
	},
	"aws-session-manager": {
		"prefix": "aws-session-manager",
		"body": [
			"RUN curl \"https://s3.amazonaws.com/session-manager-downloads/plugin/latst/ubuntu_64bit/session-manager-plugin.deb\" -o \"session-manager-plugin.deb\"",
			"RUN dpkg -i session-manager-plugin.deb"
		]
	}
}
